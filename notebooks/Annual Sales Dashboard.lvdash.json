{
  "datasets": [
    {
      "name": "8d57b5e5",
      "displayName": "annual_sales_summary",
      "queryLines": [
        "SELECT d.year, p.category, o.amount  \r\n",
        "FROM brij_lakehouse.gold.fact_orders o\r\n",
        "JOIN brij_lakehouse.gold.dim_product p ON o.product_id = p.product_id \r\n",
        "JOIN brij_lakehouse.gold.dim_date d ON o.order_date = d.date\r\n",
        "ORDER BY d.year"
      ]
    }
  ],
